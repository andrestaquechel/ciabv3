# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth (Cloud Console → APIs & Services → Credentials → OAuth client)
# Enable: Google Slides API + Google Drive API
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional — AI content generation (section drafts)
OPENAI_API_KEY=

# Optional — Giphy GIF search (falls back to mock results if empty)
GIPHY_API_KEY=

# Mini Box master template in Google Slides (presentation ID from the URL)
# https://docs.google.com/presentation/d/THIS_ID/edit
MINI_BOX_TEMPLATE_ID=

# App URL
AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
