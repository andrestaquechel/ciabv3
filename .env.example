# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth — Drive + Slides read (Knowledge Base)
# Redirect: https://YOUR_DOMAIN/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_URL=https://ciabv2-gilt.vercel.app
NEXT_PUBLIC_APP_URL=https://ciabv2-gilt.vercel.app

# Optional — Anthropic Claude for AI generate, research, and Knowledge Base Q&A
ANTHROPIC_API_KEY=
# Optional shared Google Drive folder ID for team app settings (Claude model, folder config).
# If unset, a "Box Studio Data" folder is created in the signed-in user's My Drive.
# BOX_STUDIO_DATA_FOLDER_ID=
# Optional override (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=
GIPHY_API_KEY=
